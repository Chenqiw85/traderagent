# Copy this file to .env and fill in the keys you need.

# LLM provider (required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Data sources — at least one of these is needed for OHLCV data
FINNHUB_API_KEY=your_finnhub_api_key_here

# Uncomment if you add other LLM providers:
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GEMINI_API_KEY=your_gemini_key_here
# SILICONFLOW_API_KEY=your_siliconflow_key_here

# RAG mode auto-detection:
# Full RAG (persistent): set both OPENAI_API_KEY and QDRANT_URL
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_here

# In-memory RAG (local): set OLLAMA_HOST
# OLLAMA_HOST=http://localhost:11434

# Database (required for stable data fetching)
# IMPORTANT: Change the password before deploying!
DATABASE_URL=postgresql://trader:CHANGEME@localhost:5433/traderagent
POSTGRES_PASSWORD=CHANGEME

# WhatsApp (optional — sends advisor reports via WhatsApp Web)
# First run will display a QR code in terminal — scan with your phone
# WHATSAPP_AUTH_DIR=.whatsapp-auth
# ADVISOR_WHATSAPP_TO=+1234567890
