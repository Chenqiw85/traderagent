{
  "name": "traderagent",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "run:analyze": "tsx --env-file=.env src/run.ts",
    "trader:train": "tsx --env-file=.env src/cli/train.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:sync": "tsx --env-file=.env src/cli/sync.ts",
    "scheduler:start": "tsx --env-file=.env src/cli/scheduler.ts",
    "watchlist:add": "tsx --env-file=.env src/cli/watchlist.ts add",
    "watchlist:remove": "tsx --env-file=.env src/cli/watchlist.ts remove",
    "watchlist:list": "tsx --env-file=.env src/cli/watchlist.ts list",
    "advisor": "tsx --env-file=.env src/cli/advisor.ts",
    "advisor:schedule": "tsx --env-file=.env src/cli/advisor.ts schedule",
    "test:whatsapp": "tsx --env-file=.env src/cli/test-whatsapp.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.15.0",
    "@polygon.io/client-js": "^7.2.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "finnhub": "^1.2.17",
    "node-cron": "^4.2.1",
    "ollama": "^0.5.0",
    "openai": "^4.0.0",
    "p-queue": "^9.1.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
