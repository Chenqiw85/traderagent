generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  ticker    String   @unique
  market    String   // US, CN, HK
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ohlcv {
  id       Int      @id @default(autoincrement())
  ticker   String
  market   String
  date     DateTime
  open     Float
  high     Float
  low      Float
  close    Float
  volume   BigInt
  source   String
  fetchedAt DateTime @default(now())

  @@unique([ticker, date])
  @@index([ticker])
}

model Fundamentals {
  id       Int      @id @default(autoincrement())
  ticker   String
  market   String
  data     Json
  source   String
  fetchedAt DateTime @default(now())

  @@index([ticker])
}

model News {
  id          Int      @id @default(autoincrement())
  ticker      String
  market      String
  title       String
  url         String   @unique
  source      String
  publishedAt DateTime
  data        Json?
  fetchedAt   DateTime @default(now())

  @@index([ticker])
}

model Technicals {
  id         Int      @id @default(autoincrement())
  ticker     String
  market     String
  date       DateTime
  indicators Json
  computedAt DateTime @default(now())

  @@unique([ticker, date])
  @@index([ticker])
}

model FetchLog {
  id       Int      @id @default(autoincrement())
  ticker   String
  market   String
  dataType String
  source   String
  status   String   // success, failed
  error    String?
  duration Int      // milliseconds
  fetchedAt DateTime @default(now())

  @@index([ticker])
  @@index([fetchedAt])
}

model BacktestRun {
  id             String             @id @default(uuid())
  ticker         String
  market         String
  startDate      DateTime
  endDate        DateTime
  passNumber     Int
  windowType     String
  totalDays      Int
  winRate        Float
  compositeScore Float
  createdAt      DateTime           @default(now())
  decisions      BacktestDecision[]

  @@index([ticker])
}

model BacktestDecision {
  id             String      @id @default(uuid())
  runId          String
  run            BacktestRun @relation(fields: [runId], references: [id])
  date           DateTime
  action         String
  confidence     Float
  stopLoss       Float?
  takeProfit     Float?
  actualReturn   Float
  hitTakeProfit  Boolean
  hitStopLoss    Boolean
  compositeScore Float
  reasoning      String

  @@index([runId])
}

model Lesson {
  id         String   @id @default(uuid())
  ticker     String
  market     String
  passNumber Int
  condition  String
  lesson     String
  evidence   String
  confidence Float
  createdAt  DateTime @default(now())

  @@index([ticker])
  @@index([passNumber])
}
